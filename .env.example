# Network Gate environment variables
# Copy this file to .env and adjust values as needed

# Port the web UI and API will listen on
PORT=8080

# Network interface to apply traffic shaping on
# Run `ip link` on the host to find the correct interface name
INTERFACE=eth0

# SQLite database file path (inside the container)
DB_PATH=/data/gate.db

# Log level: debug | info | warning | error
LOG_LEVEL=info
